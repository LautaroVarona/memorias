\par {\listtext\pard\plain\ltrpar \rtlch\fcs1 \af1\afs20 \ltrch\fcs0 \f37\fs20\insrsid4208853\charrsid11619503 \hich\af37\dbch\af31505\loch\f37 -\tab}\hich\af1\dbch\af31505\loch\f1 \hich\f1 Deudas con entidades de cr\'e9\loch\f1 dito.
